<div class="row mainDiv2">
    <div class="col">
        <h1 class="text-center" style="color: rgb(0, 0, 0);">Contest  Portfolio</h1>
    </div>


</div>



<div class="row mainDiv2">
    <div class="col" style="border-style: solid; padding: 0%;">
        <div class="table-responsive" style="background-color: black;">
            <table class="table">
                <thead style="background-color: black; color: white;">

                    <tr>
                        <th class="text-center">Rank<br><br></th>
                        <th>ID<br><br></th>
                        <th>Name<br><br></th>
                        <!-- Current Price <br><button id="reloCurrValue"> ↺</button> </th> -->
                        <th> Current Price <br> .
                        </th>
                        <th>Invested<br>Price<br></th>
                        <th>Profit<br>Gained</th>
                        <th>Sell<br><br></th>
                    </tr>



                </thead>

                <tbody id="tbody2">


                    {{#ifEqual cls "user"}}

                    {{else}}
                    
                    {{#each cls}}

                    {{#ifCond this.coin_profit 0}}
                    <tr class="table-danger">
                        {{else}}
                    <tr class="table-success">
                        {{/ifCond}}

                        <td style="width: 25.66670000000001px;">1</td>
                        <td>{{this.coin_symbol}}</td>
                        <td>
                            <strong>
                                {{this.coin_name}}
                            </strong>
                        </td>
                        <td>{{this.coin_current}}</td>
                        <td>{{this.coin_invested_amount}}</td>
                        <td>
                            <strong>
                                {{this.coin_profit}}
                            </strong>
                        </td>
                        <td>
                            <div>
                                <form action="/C_selling_coin" method="post">

                                    <button class="btn btn-danger btn-lg" type="submit" name="arrayIndex" style="margin: 0px;
                                     padding: 1px 14px;
                                     margin-bottom: 12px;" value={{@index}}>
                                        SELL
                                    </button>

                                </form>

                            </div>
                        </td>
                    </tr>
                    {{/each}}
                    {{/ifEqual}}




                </tbody>

                <tfoot style="background-color: rgb(0, 0, 0); ">
                    {{#ifCond C_myPortfolio_total_profit 0}}
                    <td></td>
                    <td></td>
                    <td></td>

                    <td style="color: red;"> {{C_myPortfolio_total_Current}} </td>
                    <td style="color: red;"> {{C_myPortfolio_total_invested}} </td>
                    <td style="color: red;"> {{C_myPortfolio_total_profit}} </td>
                    <td></td>

                    {{else}}
                    <td></td>
                    <td></td>
                    <td></td>

                    <td style="color: rgb(52, 202, 52);;"> {{C_myPortfolio_total_Current}} </td>
                    <td style="color: rgb(52, 202, 52);;"> {{C_myPortfolio_total_invested}} </td>
                    <td style="color: rgb(52, 202, 52);;"> {{C_myPortfolio_total_profit}} </td>
                    <td></td>
                    {{/ifCond}}
                </tfoot>

            </table>

            {{!-- <table class="table" id="portfolioSummary">
                <thead>
                    <th class="text-center">Total <br> Coins <br>=</th>
                    <th class="text-center" style="background-color: red;">Total <br> Investment <br>=
                    </th>
                    <th class="text-center">Current <br> Value <br>=</th>
                    <th class="text-center">Current <br> Profit <br>=</th>

                </thead>
                <tbody>

                    <tr class="table-info">
                        <th id="holding"><br> 900 <br></th>
                        <th id="InvestmentTotal"><br> 900 <br></th>
                        <th id="currentTotal"> 800 <br> <br> </th>
                        <th id="currentProfit">780<br><br> </th>

                    </tr>
                </tbody>
            </table> --}}
        </div>
    </div>
</div>